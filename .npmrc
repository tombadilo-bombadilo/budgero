public-hoist-pattern[]=*shiki*
public-hoist-pattern[]=*unist*
public-hoist-pattern[]=*hast*
public-hoist-pattern[]=*mdast*
public-hoist-pattern[]=*rehype*
public-hoist-pattern[]=*remark*
public-hoist-pattern[]=*micromark*
public-hoist-pattern[]=vfile*
public-hoist-pattern[]=unified

# Let pnpm reinstall stale node_modules from non-TTY contexts (husky hooks,
# CI). Without this, pnpm 11's pre-run deps check aborts with
# ERR_PNPM_ABORTED_REMOVE_MODULES_DIR_NO_TTY whenever node_modules was last
# touched by a different pnpm version.
confirm-modules-purge=false
