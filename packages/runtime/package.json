{
  "name": "@budgero/runtime",
  "version": "1.0.0",
  "license": "FSL-1.1-ALv2",
  "private": true,
  "description": "Runtime engine for Budgero — crypto, sync, offline queue, state machine coordinator",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "lz4js": "^0.2.0"
  },
  "devDependencies": {
    "@budgero/eslint-config": "workspace:*",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.30.1",
    "globals": "^15.15.0",
    "typescript": "~5.6.2",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist"
  ]
}
