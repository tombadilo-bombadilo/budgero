# Copy to .env.local to override defaults during local dev,
# or set these in your deployment platform (Dokploy / Vercel / etc.).
# All values need the NEXT_PUBLIC_ prefix to reach client components.
# If unset, the defaults in src/lib/pricing.ts are used.

# Display pricing shown across landing pages, comparisons, and blog posts.
# Include the $ sign — these are rendered verbatim.
# The monthly-equivalent of the yearly plan (shown as "Equivalent to X/month")
# is computed automatically from the yearly price — don't set it separately.
NEXT_PUBLIC_BUDGERO_PRICE_MONTHLY=$7.99
NEXT_PUBLIC_BUDGERO_PRICE_YEARLY=$60
